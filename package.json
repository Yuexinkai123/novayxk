{
  "name": "novayxk",
  "version": "0.4.6",
  "private": true,
  "description": "Novayxk - a universal AI coding assistant desktop app.",
  "main": "electron/main.cjs",
  "author": "Novayxk",
  "scripts": {
    "dev": "npm run setup:desktop && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && npm run desktop\"",
    "web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "node scripts/run-electron.cjs .",
    "setup:desktop": "node scripts/setup-electron.cjs",
    "icons": "node scripts/generate-icons.cjs && node scripts/generate-installer-art.cjs",
    "cleanup": "node scripts/build-cleanup-helper.cjs",
    "pack": "npm run icons && npm run build && npm run setup:desktop && node scripts/package-electron.cjs --dir --fast",
    "pack:full": "npm run icons && npm run build && npm run setup:desktop && node scripts/package-electron.cjs --dir",
    "package": "npm run icons && npm run build && npm run setup:desktop && node scripts/package-electron.cjs --win nsis",
    "package:portable": "npm run icons && npm run build && npm run setup:desktop && node scripts/package-electron.cjs --win portable",
    "package:custom": "npm run icons && npm run build && npm run setup:desktop && node scripts/package-electron.cjs --dir --fast && node scripts/build-custom-installer.cjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "electron": "33.4.11",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.novayxk.app",
    "productName": "Novayxk",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/",
      "cache": ".electron-cache"
    },
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icons/**/*",
      "scripts/after-pack.cjs",
      "package.json"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "icon": "assets/icons/novayxk.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Novayxk",
      "include": "build/installer.nsh",
      "installerIcon": "assets/icons/novayxk.ico",
      "uninstallerIcon": "assets/icons/novayxk.ico",
      "installerSidebar": "assets/installer/installerSidebar.bmp",
      "uninstallerSidebar": "assets/installer/uninstallerSidebar.bmp",
      "installerHeader": "assets/installer/installerHeader.bmp",
      "artifactName": "Novayxk-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Novayxk-Portable-${version}.${ext}"
    }
  }
}
